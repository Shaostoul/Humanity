// HumanityOS Plumbing System Definitions
// Water supply, drainage, treatment, and storage for colony infrastructure.
// Loaded by AssetManager, hot-reloadable.
//
// flow_rate_lps = liters per second at rated pressure.
// pressure_rating_bar = max safe operating pressure.
// water_consumption_lps = average draw when fixture is active.
// throughput_lps = treatment capacity in liters per second.
// efficiency = fraction of input water recovered as clean output (0.0-1.0).

(
    // =========================================================================
    // PIPE TYPES (4) - Fluid conduits
    // =========================================================================

    pipes: [
        (
            id: "pvc_pipe",
            name: "PVC Pipe",
            flow_rate_lps: 2.5,
            pressure_rating_bar: 10,
            temperature_max_c: 60,
            cost_per_meter: 1.5,
            weight_kg_per_m: 0.8,
            inner_diameter_mm: 50,
            lifespan_years: 50,
            description: "Lightweight plastic pipe for cold water supply and drainage",
        ),
        (
            id: "copper_pipe",
            name: "Copper Pipe",
            flow_rate_lps: 3.0,
            pressure_rating_bar: 20,
            temperature_max_c: 150,
            cost_per_meter: 8.0,
            weight_kg_per_m: 1.2,
            inner_diameter_mm: 50,
            lifespan_years: 70,
            description: "Durable metal pipe for hot and cold supply, naturally antimicrobial",
        ),
        (
            id: "steel_pipe",
            name: "Steel Pipe",
            flow_rate_lps: 5.0,
            pressure_rating_bar: 40,
            temperature_max_c: 300,
            cost_per_meter: 12.0,
            weight_kg_per_m: 3.5,
            inner_diameter_mm: 75,
            lifespan_years: 40,
            description: "Heavy-duty high-pressure pipe for industrial fluid and steam lines",
        ),
        (
            id: "flexible_hose",
            name: "Flexible Hose",
            flow_rate_lps: 1.5,
            pressure_rating_bar: 6,
            temperature_max_c: 80,
            cost_per_meter: 3.0,
            weight_kg_per_m: 0.3,
            inner_diameter_mm: 25,
            lifespan_years: 10,
            description: "Reinforced rubber hose for temporary connections and vibration isolation",
        ),
    ],

    // =========================================================================
    // FIXTURES (8) - End-use water points
    // =========================================================================

    fixtures: [
        (
            id: "toilet",
            name: "Toilet",
            water_consumption_lps: 0.1,
            requires_drain: true,
            requires_vent: true,
            flush_volume_l: 6.0,
            description: "Gravity or vacuum flush waste disposal, requires sewage connection",
        ),
        (
            id: "sink",
            name: "Sink",
            water_consumption_lps: 0.12,
            requires_drain: true,
            requires_vent: false,
            flush_volume_l: 0.0,
            description: "Basin with hot/cold supply for hand washing and food preparation",
        ),
        (
            id: "shower",
            name: "Shower",
            water_consumption_lps: 0.15,
            requires_drain: true,
            requires_vent: false,
            flush_volume_l: 0.0,
            description: "Overhead spray for personal hygiene, uses greywater drain",
        ),
        (
            id: "bathtub",
            name: "Bathtub",
            water_consumption_lps: 0.2,
            requires_drain: true,
            requires_vent: false,
            flush_volume_l: 0.0,
            fill_volume_l: 150.0,
            description: "Soaking vessel for hygiene and therapeutic use",
        ),
        (
            id: "drinking_fountain",
            name: "Drinking Fountain",
            water_consumption_lps: 0.05,
            requires_drain: true,
            requires_vent: false,
            flush_volume_l: 0.0,
            description: "Filtered potable water dispenser for public areas",
        ),
        (
            id: "fire_hydrant",
            name: "Fire Hydrant",
            water_consumption_lps: 15.0,
            requires_drain: false,
            requires_vent: false,
            flush_volume_l: 0.0,
