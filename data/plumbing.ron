            description: "High-flow emergency fire suppression outlet",
        ),
        (
            id: "irrigation_head",
            name: "Irrigation Head",
            water_consumption_lps: 0.08,
            requires_drain: false,
            requires_vent: false,
            flush_volume_l: 0.0,
            spray_radius_m: 3.0,
            description: "Pop-up or drip emitter for agricultural plot watering",
        ),
        (
            id: "industrial_drain",
            name: "Industrial Floor Drain",
            water_consumption_lps: 0.0,
            requires_drain: true,
            requires_vent: true,
            flush_volume_l: 0.0,
            max_intake_lps: 5.0,
            description: "Heavy-duty floor drain with grate for workshop and processing areas",
        ),
    ],

    // =========================================================================
    // TREATMENT SYSTEMS (8) - Water purification and recycling
