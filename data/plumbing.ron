            name: "Sewage Processor",
            throughput_lps: 1.5,
            power_draw_watts: 3000,
            efficiency: 0.85,
            filter_lifespan_l: 0,
            removes: ["organic_waste", "pathogens", "nitrogen", "phosphorus"],
            outputs: ["greywater", "biosolids", "methane"],
            description: "Aerobic digestion plant converting blackwater to reusable greywater and fertilizer",
