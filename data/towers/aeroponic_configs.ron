                (plant: "zucchini", slots: 1, role: "Fruiting", note: "Prolific, vitamin C, potassium."),
                (plant: "tomato", slots: 1, role: "Fruiting", note: "Vitamin C, lycopene."),
                (plant: "pepper", slots: 1, role: "Fruiting", note: "Very high vitamin C."),
                (plant: "eggplant", slots: 1, role: "Fruiting", note: "Fiber, antioxidants."),
                (plant: "okra", slots: 1, role: "Fruiting", note: "Fiber, vitamin C, folate."),
