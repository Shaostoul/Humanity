        (
            id: "apothecary",
            name: "Variety Herbs and Remedies",
            purpose: "Maximum variety of culinary and medicinal herbs in one tower",
            description: "One of each cooking herb, tea herb, and traditional remedy plant, to show the range an apothecary tower can hold. Pair it with the nutrition tower for flavor and home remedies.",
            covers: [
                "Cooking herbs",
                "Digestive aids",
                "Calming and sleep teas",
                "Immune tonics",
                "Topical skin remedies",
            ],
            gaps: [],
            gaps_note: "",
            disclaimer: "Culinary and traditional / folk uses, not medical advice. Some plants carry cautions (topical only, sedative, drug interactions, not for pregnancy), noted per plant. Consult a professional before any medicinal use.",
            slots: 50,
            // Narrow + coarse helix: a slim column with widely spaced plants.
            diameter_m: 0.32,
            height_m: 1.9,
            helix_turns: 2.5,
            plantings: [
                (plant: "basil", slots: 1, role: "Culinary", note: "Cooking staple."),
                (plant: "mint", slots: 1, role: "Culinary and tea", note: "Digestive; refreshing."),
                (plant: "oregano", slots: 1, role: "Culinary", note: "Antimicrobial, antioxidant."),
                (plant: "thyme", slots: 1, role: "Culinary", note: "Antiseptic; for coughs."),
                (plant: "rosemary", slots: 1, role: "Culinary", note: "Antioxidant; focus."),
                (plant: "sage", slots: 1, role: "Culinary", note: "Sore-throat; antimicrobial."),
                (plant: "parsley", slots: 1, role: "Culinary", note: "Vitamin-rich; diuretic."),
                (plant: "cilantro", slots: 1, role: "Culinary", note: "Coriander seed; digestive."),
                (plant: "dill", slots: 1, role: "Culinary", note: "Pickling; digestion."),
                (plant: "chive", slots: 1, role: "Culinary allium", note: "Mild onion flavor."),
                (plant: "lemongrass", slots: 1, role: "Culinary and tea", note: "Citrus; antimicrobial."),
                (plant: "chamomile", slots: 1, role: "Calming tea", note: "Sleep, digestion."),
                (plant: "lavender", slots: 1, role: "Aromatic", note: "Calm, sleep."),
                (plant: "ginger", slots: 1, role: "Spice (rhizome)", note: "Nausea, digestion. Partial fit."),
                (plant: "turmeric", slots: 1, role: "Spice (rhizome)", note: "Anti-inflammatory. Partial fit."),
                (plant: "saffron", slots: 1, role: "Spice (corm)", note: "Precious spice. Partial fit."),
                (plant: "hop", slots: 1, role: "Brewing (vine)", note: "Bittering; calming. Partial fit."),
                (plant: "echinacea", slots: 1, role: "Medicinal", note: "Traditionally immune support."),
                (plant: "valerian", slots: 1, role: "Medicinal (sedative)", note: "Traditionally for sleep. Caution: sedative."),
                (plant: "feverfew", slots: 1, role: "Medicinal", note: "Traditionally for migraines. Not in pregnancy."),
                (plant: "calendula", slots: 1, role: "Medicinal (topical)", note: "Skin-healing salve. Topical."),
                (plant: "st_johns_wort", slots: 1, role: "Medicinal (mood)", note: "Traditionally for mood. Caution: interactions."),
                (plant: "comfrey", slots: 1, role: "Medicinal (topical)", note: "Bruise poultice. Topical only."),
                (plant: "aloe_vera", slots: 1, role: "Medicinal (succulent)", note: "Skin gel. Partial fit."),
            ],
        ),
    ],
)
