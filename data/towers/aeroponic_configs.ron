            parts: [
                (name: "Tower column (stacking pots or a 0.6 m food-safe pipe with 50 net-cup ports)", qty: "1", source: "3d_print", note: "The vertical body. 3D-print stacking sections, or cut ports into HDPE/PVC pipe."),
                (name: "Net cups, 3 inch", qty: "50", source: "3d_print", note: "One per plant slot. Reusable; printable in PETG."),
                (name: "Reservoir tank, food-grade (~80 L)", qty: "1", source: "scavenge", note: "A clean food barrel or tote. A bigger reservoir holds nutrients steadier."),
