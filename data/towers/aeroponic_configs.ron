                (plant: "chickpea", slots: 1, role: "Legume", note: "Protein, fiber."),
                (plant: "parsley", slots: 1, role: "Herb (nutrition)", note: "Vitamin C and K."),
                (plant: "cilantro", slots: 1, role: "Herb", note: "Fresh flavor; digestion."),
