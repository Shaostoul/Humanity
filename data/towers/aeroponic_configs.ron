// Aeroponic tower configurations (v0.383: reframed to MAXIMUM VARIETY).
//
// Two curated vertical aeroponic towers, the homestead's FOOD loop made concrete
// (see docs/design/self-sufficiency.md). Philosophy (operator 2026-06-07): "as
// many variety as possible" -- ONE of each plant rather than ten of one, to show
// how wide a range a person can easily grow. Every plant is an existing id in
// data/plants.csv (no new plant data). `slots` is the tower's net-cup CAPACITY
// (50); the plantings use as many DISTINCT varieties as plants.csv currently
// offers for that tower, leaving room for the community to add more.
//
// "They all grow together": in AEROPONICS the plants share one nutrient reservoir
// and the room's air, NOT soil, so soil-based companion/adverse rules relax (no
// allelopathy or soil-pest sharing). The real compatibility constraint is a shared
// reservoir pH and a shared temperature/humidity window. A compatibility check
// (computing that shared window from plants.csv) is the next feature.
//
// The medicinal notes are CULINARY and TRADITIONAL/folk uses, not medical advice.
// No em-dashes (the strings render in-app, where em-dashes are banned).

(
    towers: [
        (
            id: "nutrition",
            name: "Variety Greens and Beans",
            purpose: "Maximum variety of food crops in one aeroponic tower",
            description: "An ideal minimalistic vegetable garden showing how many different things you can easily grow in one vertical tower: one of each leafy green, brassica, root, allium, fruiting vegetable, legume, and kitchen herb. Swap or add freely; the community will tune the perfect mix.",
            covers: [
                "Vitamin A",
                "Vitamin C",
                "Vitamin K",
                "Folate and B vitamins",
                "Iron",
                "Calcium",
                "Potassium and magnesium",
                "Fiber",
                "Plant protein (legumes)",
            ],
            gaps: [
                "Bulk calories (grains, tubers)",
                "Fats and oils",
                "Vitamin B12",
                "Vitamin D",
                "Omega-3",
            ],
            gaps_note: "These come from field crops, the ranch tier, sunlight, or animals, not from a tower.",
            disclaimer: "",
            slots: 50,
            // Wide + fine helix: a fat column packed with many plants.
            diameter_m: 0.6,
            height_m: 2.4,
            helix_turns: 6.0,
            plantings: [
                (plant: "lettuce", slots: 1, role: "Leafy green", note: "Salad base, vitamin A, folate."),
                (plant: "spinach", slots: 1, role: "Leafy green", note: "Iron, folate, magnesium."),
                (plant: "kale", slots: 1, role: "Leafy green", note: "Vitamin A, C, K, calcium."),
                (plant: "cabbage", slots: 1, role: "Brassica", note: "Vitamin C, K, fiber."),
                (plant: "broccoli", slots: 1, role: "Brassica", note: "Vitamin C, K, sulforaphane."),
                (plant: "cauliflower", slots: 1, role: "Brassica", note: "Vitamin C, choline."),
                (plant: "beet", slots: 1, role: "Root and greens", note: "Folate; edible greens."),
                (plant: "turnip", slots: 1, role: "Root and greens", note: "Vitamin C; edible tops."),
                (plant: "radish", slots: 1, role: "Root (fast)", note: "Fast, vitamin C, peppery."),
                (plant: "carrot", slots: 1, role: "Root", note: "Vitamin A (beta-carotene)."),
                (plant: "parsnip", slots: 1, role: "Root", note: "Sweet, fiber, potassium."),
                (plant: "celery", slots: 1, role: "Stalk", note: "Crunch, vitamin K, hydration."),
                (plant: "leek", slots: 1, role: "Allium", note: "Mild onion, vitamin K."),
                (plant: "onion", slots: 1, role: "Allium", note: "Flavor base, antioxidants."),
