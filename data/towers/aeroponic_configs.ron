                (name: "Riser tube + top distribution cap", qty: "1 set", source: "3d_print", note: "Carries water up; the cap cascades it down over the roots."),
                (name: "Repeat cycle timer", qty: "1", source: "buy", note: "Pulses the pump (for example 15 min on / 15 off) to aerate the roots."),
                (name: "Net-cup medium, clay pebbles", qty: "~12 L", source: "buy", note: "Cradles the seedlings; rinse and reuse between crops."),
                (name: "Hydroponic nutrients (A + B)", qty: "per reservoir", source: "diy", note: "Mineral salts. Mix from bulk salts once you learn the recipe."),
                (name: "pH test kit + pH up/down", qty: "1", source: "buy", note: "Keep the shared reservoir inside the plants' common pH window."),
            ],
        ),
        (
