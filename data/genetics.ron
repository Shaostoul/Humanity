            description: "Genetically driven hostile temperament. Difficult to tame and dangerous to handlers.",
            applies_to: "animal",
            inheritance_pattern: "codominant",
            carrier_frequency: 0.07,
            trait_penalties: [("animal_temperament", -0.50)],
            lethal: false,
            treatable: false,
            cure_tech: "genetic_engineering",
            visual_sign: "aggressive_posture",
        ),
        (
            id: "animal_blindness",
            name: "Congenital Blindness",
            description: "Born without functional eyes. Severely limits navigation and predator avoidance.",
            applies_to: "animal",
            inheritance_pattern: "recessive",
            carrier_frequency: 0.03,
            trait_penalties: [("animal_speed", -0.40), ("animal_intelligence", -0.20)],
            lethal: false,
            treatable: true,
            cure_tech: "nanotechnology",
            visual_sign: "clouded_eyes",
        ),
    ],

    // =========================================================================
    // BREEDING CONFIGURATION
    // =========================================================================

    breeding_config: (
        // How many generations of selective breeding before diminishing returns
        max_effective_generations: 20,

        // Inbreeding coefficient threshold. Above this, negative mutations increase sharply.
        inbreeding_threshold: 0.25,
        inbreeding_mutation_multiplier: 3.0,

        // Trait inheritance formula:
        // offspring_trait = (parent_a_trait + parent_b_trait) / 2
        //   + random(-offspring_variation, +offspring_variation)
        //   + mutation_modifier (if mutation rolls)

        // Minimum genetic distance for hybridization to be attempted
        hybridization_min_similarity: 0.60,

        // Seed banking: harvested seeds retain parent genetics indefinitely
        seed_bank_degradation: false,

        // Frozen genetics: stored animal genetic material has a shelf life
        frozen_material_shelf_life_days: 365,
        cryogenic_shelf_life_days: 36500,
    ),
)
