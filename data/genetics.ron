    // =========================================================================
    // MUTATION SYSTEM
    // =========================================================================
    // When a trait mutates, the type of mutation is rolled from these weights.
    // beneficial mutations improve the trait, detrimental worsen it,
    // neutral mutations change appearance without affecting function.

    mutation_types: [
        (
            id: "beneficial",
            name: "Beneficial Mutation",
            description: "A lucky genetic change that improves one or more traits beyond parental values",
            weight: 0.10,
            trait_modifier_min: 0.05,
            trait_modifier_max: 0.20,
            direction: "positive",
            visual_indicator: "faint_glow",
        ),
        (
            id: "neutral_color",
            name: "Color Variation",
            description: "Cosmetic pigment change. New fur, petal, or skin color with no functional effect.",
            weight: 0.20,
            trait_modifier_min: 0.0,
            trait_modifier_max: 0.0,
            direction: "none",
            visual_indicator: "color_shift",
        ),
        (
            id: "neutral_pattern",
            name: "Pattern Variation",
            description: "New spot, stripe, or marking pattern. Visually distinct but functionally identical.",
            weight: 0.15,
            trait_modifier_min: 0.0,
            trait_modifier_max: 0.0,
            direction: "none",
            visual_indicator: "pattern_change",
        ),
        (
            id: "neutral_size_minor",
            name: "Minor Size Variation",
            description: "Slightly larger or smaller than expected. Within normal range, no gameplay impact.",
            weight: 0.15,
            trait_modifier_min: -0.02,
            trait_modifier_max: 0.02,
            direction: "none",
            visual_indicator: "size_tweak",
        ),
        (
            id: "neutral_texture",
            name: "Texture Variation",
            description: "Different leaf shape, feather pattern, or fur texture. Cosmetic only.",
            weight: 0.10,
            trait_modifier_min: 0.0,
            trait_modifier_max: 0.0,
            direction: "none",
            visual_indicator: "texture_change",
        ),
        (
            id: "detrimental_mild",
            name: "Mild Detrimental Mutation",
            description: "A small negative genetic shift. Slightly reduces one trait.",
            weight: 0.15,
            trait_modifier_min: -0.10,
            trait_modifier_max: -0.03,
            direction: "negative",
            visual_indicator: "slight_discoloration",
        ),
        (
            id: "detrimental_severe",
            name: "Severe Detrimental Mutation",
            description: "A significant genetic defect. Noticeably reduces one or more traits.",
            weight: 0.10,
            trait_modifier_min: -0.25,
            trait_modifier_max: -0.10,
            direction: "negative",
            visual_indicator: "visible_deformity",
        ),
        (
            id: "detrimental_lethal",
            name: "Lethal Mutation",
            description: "Fatal genetic defect. Organism dies before reaching maturity or is stillborn.",
            weight: 0.05,
            trait_modifier_min: -1.0,
            trait_modifier_max: -1.0,
            direction: "lethal",
            visual_indicator: "none",
        ),
    ],

