# ── Build artifacts ──
/target/
/HumanityOS.exe
/v*_HumanityOS.exe
/v*_HumanityOS.exe.sig.json
/release-manifest.json
/release-manifest.json.sig.json
*.old.exe

# ── Release signing PRIVATE key vault (NEVER commit) ──
# The encrypted hybrid Ed25519+Dilithium3 signing seeds (src/release_update.rs
# --gen-release-key). Only the PUBLIC keys (data/release/signing_pubkeys.json)
# are committed. Back this file up encrypted, offline; losing it means you must
# rotate to a new signing key. The audit's CRITICAL fix depends on this staying
# off GitHub.
/release-signing-key.enc
*.signing-key.enc
# Updater handoff: the running app writes the target exe path here before
# restarting into a new build (src/updater.rs). Machine-local + transient.
/restart_target.txt

# ── Runtime data (local only, never committed) ──
# Project Universe (shaostoul.com) archive staging — texts get curated into
# docs/history/ deliberately; the bulky 2020-era media is staged here for the
# relay media catalog and must NOT bloat git. See scripts/archive-wordpress.js.
/_pu-archive/
/logs/*
!/logs/.gitkeep
/saves/*
!/saves/.gitkeep
/backups/*
!/backups/.gitkeep
/config.json

# ── Dependencies ──
node_modules/

# ── Logs ──
*.log

