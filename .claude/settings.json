{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hook-theme-sync.js",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hook-push-guard.js",
            "if": "Bash(git push*)",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "just clean-worktrees",
            "timeout": 120,
            "statusMessage": "Cleaning stale worktrees"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/precompact-reminder.js",
            "timeout": 10,
            "statusMessage": "Flushing durable state before compaction"
          }
        ]
      }
    ]
  }
}
